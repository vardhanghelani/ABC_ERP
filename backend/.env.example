NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/jewellery_erp

# Required in production (minimum 32 characters each)
JWT_ACCESS_SECRET=change-me-to-a-long-random-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-to-a-long-random-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

CLIENT_URL=http://localhost:5173

# Optional — product image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
